FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

# Create a secure non-root user
RUN useradd -u 10001 -m appuser

# Install only the lightweight frontend requirements
COPY requirements.frontend.txt .
RUN pip install --no-cache-dir -r requirements.frontend.txt

# Copy the frontend application code
COPY frontend/ ./frontend/

RUN chown -R appuser:appuser /app
USER appuser

# Streamlit defaults to 8501 locally
EXPOSE 8501

# Render injects $PORT dynamically at runtime
CMD ["sh", "-c", "streamlit run frontend/app.py --server.port ${PORT:-8501} --server.address 0.0.0.0"]